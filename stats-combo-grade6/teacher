<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Статистика және Комбинаторика — Мұғалім</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root{
  --bg:#f0f2f8;--bg2:#ffffff;--bg3:#e6e9f0;
  --border:#d2d6e2;--border2:#bcc2d3;
  --text:#141826;--text2:#3b4063;--muted:#7a7f9a;
  --primary:#4338ca;--primary-light:#eef0ff;--primary-dark:#3730a3;
  --green:#059669;--green-light:#ecfdf5;--green-border:#6ee7b7;
  --red:#dc2626;--red-light:#fef2f2;--red-border:#fca5a5;
  --amber:#d97706;--amber-light:#fffbeb;--amber-border:#fcd34d;
  --r:14px;
  --shadow-sm:0 1px 3px rgba(20,24,38,.05);
  --shadow:0 2px 10px rgba(20,24,38,.07);
  --shadow-lg:0 8px 30px rgba(20,24,38,.10);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:16px;-webkit-tap-highlight-color:transparent;overflow:hidden}

.screen{display:none;position:fixed;inset:0;flex-direction:column;overflow:hidden;animation:fadeUp .3s ease}
.screen.active{display:flex}
.si{flex:1;display:flex;flex-direction:column;align-items:center;padding:14px;overflow:hidden}
.si.center{justify-content:center}
.si.top{justify-content:flex-start}

@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideIn{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:translateX(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes pop{0%{transform:scale(.9);opacity:0}100%{transform:scale(1);opacity:1}}
@keyframes cfFall{from{transform:translateY(-20px) rotate(0);opacity:1}to{transform:translateY(110vh) rotate(720deg);opacity:0}}
@keyframes breathe{0%,100%{box-shadow:0 0 0 0 rgba(5,150,105,.4)}50%{box-shadow:0 0 0 5px rgba(5,150,105,0)}}

.logo{font-size:1.5rem;font-weight:800;letter-spacing:-.5px}
.logo b{color:var(--primary)}
.logo-sub{color:var(--muted);font-size:.78rem;margin-top:2px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:16px;box-shadow:var(--shadow-sm)}
.card-title{font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:12px 20px;border:none;border-radius:12px;font-family:inherit;font-size:.88rem;font-weight:700;cursor:pointer;transition:all .15s;white-space:nowrap;touch-action:manipulation;min-height:48px}
.btn:active{transform:scale(.97)}
.btn-block{width:100%}
.btn-primary{background:var(--primary);color:#fff;box-shadow:0 2px 10px rgba(67,56,202,.3)}
.btn-green{background:var(--green);color:#fff}
.btn-red{background:var(--red);color:#fff}
.btn-ghost{background:transparent;border:1.5px solid var(--border);color:var(--muted)}
.btn-sm{padding:7px 14px;font-size:.76rem;min-height:36px}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none!important}
.chip{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700}
.chip-p{background:var(--primary-light);border:1px solid rgba(67,56,202,.2);color:var(--primary)}
.dots{display:flex;gap:5px;align-items:center}
.dot{width:7px;height:7px;border-radius:50%;background:var(--primary);animation:pulse 1.2s infinite}
.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
.err{background:var(--red-light);border:1px solid var(--red-border);border-radius:10px;padding:10px 14px;color:var(--red);font-size:.82rem;font-weight:500;display:none;margin-bottom:10px}
.err.on{display:block}

/* ── SETUP ── */
.setup-wrap{width:100%;max-width:720px;height:100%;display:flex;flex-direction:column}
.setup-hero{text-align:center;margin-bottom:16px;flex-shrink:0}
.setup-scroll{flex:1;overflow-y:auto;min-height:0;margin-bottom:12px}
.sec-group{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:18px;margin-bottom:10px;box-shadow:var(--shadow-sm)}
.sec-group-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:8px;border-bottom:1.5px solid var(--border)}
.sec-group-title{font-weight:800;font-size:.94rem}
.sec-group-all{font-size:.72rem;background:var(--bg3);border:none;padding:6px 14px;border-radius:8px;cursor:pointer;color:var(--primary);font-weight:700;touch-action:manipulation;transition:all .15s}
.sec-group-all:hover{background:var(--primary-light)}
.sec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
@media(max-width:640px){.sec-grid{grid-template-columns:repeat(2,1fr)}}
.sec-btn{padding:16px 12px;border-radius:14px;border:2.5px solid var(--border);background:var(--bg2);cursor:pointer;transition:all .2s;text-align:center;display:flex;flex-direction:column;align-items:center;gap:6px;touch-action:manipulation;min-height:72px;justify-content:center}
.sec-btn:hover{border-color:rgba(67,56,202,.4);background:var(--primary-light)}
.sec-btn:active{transform:scale(.96)}
.sec-btn.sel{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border-color:transparent;box-shadow:0 4px 16px rgba(67,56,202,.3)}
.sec-btn .sec-label{font-size:.84rem;font-weight:700;pointer-events:none}
.sec-btn .sec-ex{font-size:.66rem;opacity:.55;font-weight:600}
.sec-btn.sel .sec-ex{opacity:.75;color:#e0e7ff}

/* ── LOBBY ── */
.lobby-wrap{width:100%;max-width:860px;height:100%;display:flex;flex-direction:column}
.lobby-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:8px;flex-shrink:0}
.code-panel{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:18px 22px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;box-shadow:var(--shadow);flex-shrink:0;margin-bottom:8px}
.code-left{flex:1;min-width:180px}
.code-lbl{font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.code-val{font-family:'JetBrains Mono',monospace;font-size:2.4rem;font-weight:700;color:var(--primary);letter-spacing:8px;line-height:1}
.code-hint{font-size:.72rem;color:var(--muted);margin-top:5px}
#qr-box{cursor:pointer;flex-shrink:0}
#qr-box canvas,#qr-box img{border-radius:8px!important;display:block}
.lobby-body{flex:1;display:grid;grid-template-columns:1fr 1fr;gap:10px;min-height:0;overflow:hidden}
@media(max-width:600px){.lobby-body{grid-template-columns:1fr}}
.student-list{display:flex;flex-direction:column;gap:4px;overflow-y:auto;max-height:100%;margin-top:4px}
.s-join{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;animation:slideIn .2s ease}
.s-join-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.72rem;flex-shrink:0}
.s-join-name{font-weight:700;font-size:.82rem}
.s-join-sub{font-size:.66rem;color:var(--green)}

/* ── LIVE ── */
.live-wrap{width:100%;max-width:1200px;height:100%;display:flex;flex-direction:column}
.live-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;flex-shrink:0;margin-bottom:10px}
.live-title{font-size:1.1rem;font-weight:800}
.live-meta{font-size:.7rem;color:var(--muted)}
.live-controls{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.stat-pill{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:.72rem;font-weight:700;display:flex;align-items:center;gap:5px;white-space:nowrap}
.stat-pill.timer{font-family:'JetBrains Mono',monospace;border-color:var(--amber-border);color:var(--amber)}
.stat-pill.timer.warn{border-color:var(--red-border);color:var(--red);animation:pulse 1.5s infinite}
.code-pill{font-family:'JetBrains Mono',monospace;background:var(--primary-light);border:1px solid rgba(67,56,202,.2);color:var(--primary);border-radius:8px;padding:5px 14px;font-size:.8rem;font-weight:700;letter-spacing:3px;cursor:pointer;touch-action:manipulation}
.cards-wrap{flex:1;overflow-y:auto;min-height:0;padding:2px}
.cards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
@media(max-width:960px){.cards-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.cards-grid{grid-template-columns:repeat(2,1fr);gap:7px}}

/* ── Student card ── */
.s-card{background:var(--bg2);border:2px solid var(--border);border-radius:14px;padding:14px;position:relative;overflow:hidden;animation:pop .35s ease;transition:border-color .4s,background .4s,box-shadow .4s}
.s-card.flash-ok{border-color:var(--green)!important;background:var(--green-light)!important;box-shadow:0 0 16px rgba(5,150,105,.15)}
.s-card.flash-err{border-color:var(--red)!important;background:var(--red-light)!important;box-shadow:0 0 16px rgba(220,38,38,.15)}
.s-card[data-rank="1"]{border-color:#fbbf24;background:linear-gradient(135deg,#fffdf0,#fef9e7);box-shadow:0 2px 12px rgba(251,191,36,.12)}
.s-card[data-rank="2"]{border-color:#d1d5de;background:linear-gradient(135deg,#fafbfc,#f4f5f7)}
.s-card[data-rank="3"]{border-color:#fdba74;background:linear-gradient(135deg,#fffaf5,#fef3e2)}
.s-card-header{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.s-card-rank{font-family:'JetBrains Mono',monospace;font-size:.82rem;font-weight:800;width:24px;text-align:center;flex-shrink:0}
.s-card-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.76rem;flex-shrink:0;border:2px solid rgba(67,56,202,.12)}
.s-card-name{font-weight:700;font-size:.84rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.s-card-pct{font-family:'JetBrains Mono',monospace;font-size:1rem;font-weight:800;flex-shrink:0}
.s-card-level{font-size:.62rem;font-weight:700;background:var(--primary-light);color:var(--primary);border-radius:6px;padding:2px 7px;margin-bottom:6px;display:inline-block}
.s-card-stats-row{display:flex;gap:4px;margin-bottom:8px}
.s-stat-box{flex:1;background:var(--bg);border-radius:8px;padding:6px 4px;text-align:center}
.s-stat-val{font-family:'JetBrains Mono',monospace;font-size:.84rem;font-weight:800}
.s-stat-val.g{color:var(--green)}.s-stat-val.r{color:var(--red)}.s-stat-val.a{color:var(--amber)}
.s-bar{height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.s-bar-fill{height:100%;border-radius:3px;transition:width .5s ease}
.s-card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:8px}
.s-focus{display:flex;align-items:center;gap:4px;font-size:.64rem;font-weight:600}
.s-focus-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.s-focus-dot.on{background:var(--green);animation:breathe 2s infinite}
.s-focus-dot.off{background:var(--red);animation:pulse 1s infinite}
.s-focus-text{color:var(--muted)}
.s-focus-text.away{color:var(--red)}
.tab-warn{font-size:.58rem;color:var(--red);font-weight:700;background:var(--red-light);border:1px solid var(--red-border);border-radius:6px;padding:2px 7px;display:flex;align-items:center;gap:3px}

/* ── RESULTS ── */
.results-wrap{width:100%;max-width:800px;height:100%;display:flex;flex-direction:column;overflow:hidden}
.results-body{flex:1;overflow-y:auto;min-height:0;padding-bottom:16px}
.lb-row{display:flex;align-items:center;gap:10px;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:12px 16px;margin-bottom:6px;box-shadow:var(--shadow-sm)}
.lb-row:nth-child(1){background:#fffbeb;border-color:#fde68a}
.lb-row:nth-child(2){background:#f8f9fa;border-color:#d1d5de}
.lb-row:nth-child(3){background:#fef3e2;border-color:#fed7aa}
.lb-rank{font-family:'JetBrains Mono',monospace;font-size:.88rem;font-weight:700;width:28px;text-align:center;flex-shrink:0}
.lb-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.76rem;flex-shrink:0}
.lb-info{flex:1;min-width:0}
.lb-name{font-weight:700;font-size:.88rem}
.lb-detail{font-size:.7rem;color:var(--muted);margin-top:2px;font-family:'JetBrains Mono',monospace}
.lb-pct{font-family:'JetBrains Mono',monospace;font-size:1.1rem;font-weight:800;flex-shrink:0}

/* QR overlay */
.qr-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000;display:none;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(4px)}
.qr-overlay.on{display:flex}
.qr-modal{background:#fff;border-radius:24px;padding:36px;text-align:center;box-shadow:var(--shadow-lg);cursor:default;max-width:90vw}
.qr-modal-code{font-family:'JetBrains Mono',monospace;font-size:3rem;font-weight:700;color:var(--primary);letter-spacing:12px;margin-top:16px}
.qr-modal-hint{color:var(--muted);font-size:.84rem;margin-top:8px}

#toast{position:fixed;top:18px;left:50%;transform:translateX(-50%) translateY(-70px);background:var(--bg2);border:1px solid var(--border);border-radius:11px;padding:10px 22px;font-size:.84rem;font-weight:600;z-index:9999;transition:transform .28s ease;white-space:nowrap;box-shadow:var(--shadow-lg)}
#toast.on{transform:translateX(-50%) translateY(0)}
#toast.ok{border-color:var(--green-border);color:var(--green)}
#toast.er{border-color:var(--red-border);color:var(--red)}
.cfw{position:fixed;inset:0;pointer-events:none;z-index:50;overflow:hidden}
.cfp{position:absolute;animation:cfFall linear forwards}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
</style>
</head>
<body>
<div id="toast"></div>
<div class="cfw" id="confetti"></div>

<!-- QR overlay -->
<div class="qr-overlay" id="qr-overlay" onclick="closeQR(event)">
  <div class="qr-modal" onclick="event.stopPropagation()">
    <div id="qr-big"></div>
    <div class="qr-modal-code" id="qr-code-big">------</div>
    <div class="qr-modal-hint" id="qr-hint"></div>
  </div>
</div>

<!-- ════ SETUP ════ -->
<div class="screen active" id="s-setup">
  <div class="si center">
    <div class="setup-wrap">
      <div class="setup-hero">
        <div class="logo">📊 Статистика және <b>Комбинаторика</b></div>
        <div class="logo-sub">6-сынып · Деңгейлерді таңдаңыз</div>
      </div>
      <div class="setup-scroll">
        <div class="sec-group">
          <div class="sec-group-hdr">
            <span class="sec-group-title">📚 Деңгейлер</span>
            <button class="sec-group-all" onclick="toggleAll()">Бәрін таңдау</button>
          </div>
          <div class="sec-grid" id="sec-grid"></div>
        </div>
      </div>
      <div class="err" id="setup-err"></div>
      <button class="btn btn-green btn-block" id="create-btn" style="padding:14px;font-size:.94rem" onclick="createRoom()">🚀 Бөлме құру</button>
    </div>
  </div>
</div>

<!-- ════ LOBBY ════ -->
<div class="screen" id="s-lobby">
  <div class="si top">
    <div class="lobby-wrap">
      <div class="lobby-top">
        <div>
          <div class="logo">📊 Статистика және <b>Комбинаторика</b></div>
          <div class="logo-sub" id="lobby-secs">—</div>
        </div>
        <div style="display:flex;gap:6px;align-items:center">
          <span class="chip chip-p">10 сұрақ/деңгей · 45 мин</span>
          <button class="btn btn-ghost btn-sm" onclick="backToSetup()">← Өзгерту</button>
        </div>
      </div>
      <div class="code-panel">
        <div class="code-left">
          <div class="code-lbl">Бөлме коды</div>
          <div class="code-val" id="room-code">------</div>
          <div class="code-hint">Оқушылар QR кодты сканерлейді</div>
          <button class="btn btn-ghost btn-sm" style="margin-top:6px" onclick="copyCode()">📋 Көшіру</button>
        </div>
        <div id="qr-box" onclick="openQR()"></div>
      </div>
      <div class="lobby-body">
        <div class="card" style="display:flex;flex-direction:column;overflow:hidden">
          <div class="card-title">Оқушылар</div>
          <div style="display:flex;align-items:baseline;gap:5px;margin-bottom:4px;flex-shrink:0">
            <span style="font-size:1.8rem;font-weight:800;font-family:'JetBrains Mono',monospace;color:var(--primary)" id="lobby-count">0</span>
            <span style="color:var(--muted);font-size:.78rem">дайын</span>
          </div>
          <div class="student-list" id="lobby-list">
            <div class="dots" style="padding:8px 0"><div class="dot"></div><div class="dot"></div><div class="dot"></div><span style="color:var(--muted);font-size:.78rem;margin-left:6px">Күтілуде…</span></div>
          </div>
        </div>
        <div class="card">
          <div class="card-title">Нұсқаулық</div>
          <div style="font-size:.82rem;color:var(--muted);line-height:2">
            1. Экранды тақтаға көрсетіңіз<br>
            2. Оқушылар QR кодты сканерлейді<br>
            3. Атын жазып кіреді<br>
            4. <b style="color:var(--green)">Бастау</b> батырмасын басыңыз<br>
            <em>⏱ Сабақ 45 минутқа шектелген</em>
          </div>
        </div>
      </div>
      <div style="flex-shrink:0;margin-top:8px">
        <button class="btn btn-green btn-block" id="start-btn" onclick="startQuiz()" style="padding:14px;font-size:.94rem" disabled>▶ Бастау (оқушылар күтілуде…)</button>
      </div>
    </div>
  </div>
</div>

<!-- ════ LIVE ════ -->
<div class="screen" id="s-live">
  <div class="si top">
    <div class="live-wrap">
      <div class="live-top">
        <div>
          <div class="live-title">📊 Статистика және Комбинаторика</div>
          <div class="live-meta" id="live-meta">Тікелей</div>
        </div>
        <div class="live-controls">
          <div class="stat-pill timer" id="timer-pill">⏱ 45:00</div>
          <div class="stat-pill">👥 <span id="live-count">0</span></div>
          <div class="stat-pill">🎯 <span id="avg-pct">0</span>%</div>
          <div class="stat-pill" id="away-pill" style="display:none;border-color:var(--red-border);color:var(--red)">👀 <span id="away-count">0</span> сыртта</div>
          <div class="code-pill" id="live-code" onclick="openQR()">------</div>
          <button class="btn btn-red btn-sm" onclick="endQuiz()">⏹ Аяқтау</button>
        </div>
      </div>
      <div class="cards-wrap">
        <div class="cards-grid" id="cards-grid"></div>
      </div>
    </div>
  </div>
</div>

<!-- ════ RESULTS ════ -->
<div class="screen" id="s-results">
  <div class="si top">
    <div class="results-wrap">
      <div style="text-align:center;margin-bottom:14px;flex-shrink:0">
        <div style="font-size:2.2rem;margin-bottom:4px">🏆</div>
        <div style="font-size:1.5rem;font-weight:800;margin-bottom:3px">Нәтижелер</div>
        <div style="color:var(--muted);font-size:.82rem" id="res-sub"></div>
      </div>
      <div class="results-body">
        <div class="card" style="margin-bottom:12px">
          <div class="card-title">🏅 Рейтинг</div>
          <div id="leaderboard"></div>
        </div>
        <button class="btn btn-primary btn-block" onclick="newSession()" style="padding:14px">← Жаңа сабақ</button>
      </div>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════
const BACKEND = 'https://mathsabaq.online';
const STUDENT_URL = 'https://sultan19235.github.io/mathsabaq-apps/stats-combo-grade6/student.html';
// ═══════════════════════════════════════════════════════════════

const LEVELS = [
  { id:'lv1', label:'1-деңгей', desc:'Өте оңай' },
  { id:'lv2', label:'2-деңгей', desc:'Оңай' },
  { id:'lv3', label:'3-деңгей', desc:'Орташа' },
  { id:'lv4', label:'4-деңгей', desc:'Қиын' },
  { id:'lv5', label:'5-деңгей', desc:'Өте қиын' }
];

let sessionCode = null;
let sseSource = null;
let selectedLevels = new Set();
const students = new Map();
let timerInterval = null;
let timeLeftSec = 45 * 60;
let quizEnded = false;

// ── Sorted order cache (for detecting re-sort) ──────────────
let lastSortedIds = [];

function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function show(id) { document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function toast(msg, type) { const el = document.getElementById('toast'); el.textContent = msg; el.className = 'on ' + (type || ''); setTimeout(() => el.classList.remove('on'), 3000); }
function fmtTime(sec) { const m = Math.floor(sec / 60); const s = sec % 60; return `${m}:${s < 10 ? '0' : ''}${s}`; }

// ── Build level buttons ──────────────────────────────────────
(function() {
  document.getElementById('sec-grid').innerHTML = LEVELS.map(l => `
    <button class="sec-btn" data-sec="${l.id}" onclick="toggleSec(this)">
      <span class="sec-label">${l.label}</span>
      <span class="sec-ex">${l.desc}</span>
    </button>`).join('');
})();

function copyCode() {
  navigator.clipboard?.writeText(sessionCode).then(() => toast('✅ Көшірілді!', 'ok')).catch(fb) || fb();
  function fb() { const t = document.createElement('textarea'); t.value = sessionCode; document.body.appendChild(t); t.select(); document.execCommand('copy'); document.body.removeChild(t); toast('✅ Көшірілді!', 'ok'); }
}
function buildStudentUrl() { return `${STUDENT_URL}?code=${sessionCode}&lv=${Array.from(selectedLevels).join(',')}`; }
function openQR() {
  document.getElementById('qr-code-big').textContent = sessionCode;
  document.getElementById('qr-hint').textContent = 'QR кодты сканерлеп кіріңіз';
  const b = document.getElementById('qr-big'); b.innerHTML = '';
  try { new QRCode(b, { text: buildStudentUrl(), width: 280, height: 280, colorDark: '#141826', colorLight: '#fff', correctLevel: QRCode.CorrectLevel.M }); } catch (e) {}
  document.getElementById('qr-overlay').classList.add('on');
}
function closeQR(e) { if (e.target === document.getElementById('qr-overlay')) document.getElementById('qr-overlay').classList.remove('on'); }
function spawnConfetti() { const w = document.getElementById('confetti'); w.innerHTML = ''; const cols = ['#4338ca','#2563eb','#d97706','#059669','#dc2626','#0891b2','#7c3aed']; for (let i = 0; i < 72; i++) { const e = document.createElement('div'); e.className = 'cfp'; const s = 5 + Math.random() * 9; e.style.cssText = `left:${Math.random()*100}vw;width:${s}px;height:${s}px;background:${cols[~~(Math.random()*cols.length)]};border-radius:${Math.random()>.5?'50%':'2px'};animation-duration:${2+Math.random()*3}s;animation-delay:${Math.random()*1.4}s`; w.appendChild(e); } setTimeout(() => w.innerHTML = '', 6000); }

function toggleSec(el) { const s = el.dataset.sec; if (selectedLevels.has(s)) { selectedLevels.delete(s); el.classList.remove('sel'); } else { selectedLevels.add(s); el.classList.add('sel'); } }
function toggleAll() { const btns = document.querySelectorAll('.sec-btn'); const allSel = Array.from(btns).every(b => b.classList.contains('sel')); btns.forEach(b => { const s = b.dataset.sec; if (allSel) { selectedLevels.delete(s); b.classList.remove('sel'); } else if (!b.classList.contains('sel')) { selectedLevels.add(s); b.classList.add('sel'); } }); }

// ══════════════════════════════════════════════════════════
//  CREATE ROOM
// ══════════════════════════════════════════════════════════
async function createRoom() {
  if (!selectedLevels.size) { document.getElementById('setup-err').textContent = 'Кем дегенде 1 деңгейді таңдаңыз!'; document.getElementById('setup-err').classList.add('on'); return; }
  document.getElementById('setup-err').classList.remove('on');
  const btn = document.getElementById('create-btn'); btn.disabled = true; btn.textContent = '⏳ Бөлме құрылуда...';
  try {
    const res = await fetch(`${BACKEND}/session`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title: 'Статистика және Комбинаторика' }) });
    const data = await res.json();
    sessionCode = data.code;
    btn.disabled = false; btn.textContent = '🚀 Бөлме құру';
    showLobby();
  } catch (e) {
    btn.disabled = false; btn.textContent = '🚀 Бөлме құру';
    document.getElementById('setup-err').textContent = '❌ Серверге қосылу мүмкін болмады'; document.getElementById('setup-err').classList.add('on');
  }
}

function backToSetup() {
  if (sseSource) sseSource.close();
  students.clear(); sessionCode = null; lastSortedIds = [];
  show('s-setup');
}

// ══════════════════════════════════════════════════════════
//  LOBBY
// ══════════════════════════════════════════════════════════
function showLobby() {
  quizEnded = false;
  document.getElementById('room-code').textContent = sessionCode;
  document.getElementById('live-code').textContent = sessionCode;
  const lvNames = Array.from(selectedLevels).map(id => LEVELS.find(l => l.id === id)?.label).join(', ');
  document.getElementById('lobby-secs').textContent = lvNames;
  document.getElementById('live-meta').textContent = 'Тікелей · ' + lvNames;
  const qb = document.getElementById('qr-box'); qb.innerHTML = '';
  try { new QRCode(qb, { text: buildStudentUrl(), width: 90, height: 90, colorDark: '#141826', colorLight: '#fff', correctLevel: QRCode.CorrectLevel.M }); } catch (e) {}
  updateLobby();
  show('s-lobby');
  connectSSE();
}

// ══════════════════════════════════════════════════════════
//  START QUIZ
// ══════════════════════════════════════════════════════════
async function startQuiz() {
  if (!students.size) { toast('Оқушылар жоқ!', 'er'); return; }
  try {
    await fetch(`${BACKEND}/start`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code: sessionCode }) });
    timeLeftSec = 45 * 60;
    startTimer();
    show('s-live');
    renderAllCards(); // initial full render when going live
  } catch (e) {
    toast('❌ Серверге қосылу қатесі', 'er');
  }
}

// ══════════════════════════════════════════════════════════
//  END QUIZ
// ══════════════════════════════════════════════════════════
async function endQuiz() {
  if (!confirm('Сабақты аяқтайсыз ба?')) return;
  try {
    await fetch(`${BACKEND}/end`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code: sessionCode }) });
  } catch (_) {}
  showResults();
}

// ══════════════════════════════════════════════════════════
//  TIMER
// ══════════════════════════════════════════════════════════
function startTimer() {
  if (timerInterval) clearInterval(timerInterval);
  updateTimerDisplay();
  timerInterval = setInterval(() => {
    timeLeftSec--;
    updateTimerDisplay();
    if (timeLeftSec <= 0) { clearInterval(timerInterval); timerInterval = null; showResults(); }
  }, 1000);
}
function updateTimerDisplay() {
  const pill = document.getElementById('timer-pill');
  pill.textContent = '⏱ ' + fmtTime(Math.max(0, timeLeftSec));
  if (timeLeftSec <= 300) pill.classList.add('warn'); else pill.classList.remove('warn');
}

// ══════════════════════════════════════════════════════════
//  SSE
// ══════════════════════════════════════════════════════════
function connectSSE() {
  if (sseSource) sseSource.close();
  sseSource = new EventSource(`${BACKEND}/live?code=${sessionCode}`);

  sseSource.onmessage = (e) => {
    const data = JSON.parse(e.data);

    if (data.type === 'snapshot') {
      data.students.forEach(s => students.set(s.studentId, s));
      if (data.status === 'active' && data.timeLeft != null) timeLeftSec = data.timeLeft;
      updateLobby();
      renderAllCards();
      updateLiveStats();

    } else if (data.type === 'update') {
      const prev = students.get(data.studentId);
      students.set(data.studentId, data);

      // Check if rank order changes → full redraw
      const newSorted = getSortedIds();
      const orderChanged = newSorted.join(',') !== lastSortedIds.join(',');

      if (orderChanged) {
        renderAllCards(); // full redraw only when ranking changes
      } else {
        // Update only the changed card in-place — NO DOM recreation
        updateCardInPlace(data.studentId, prev);
        flashCard(data.studentId, prev);
      }

      updateLobby();
      updateLiveStats();

    } else if (data.type === 'ended') {
      if (!quizEnded) showResults();
      return;
    }
  };

  sseSource.onerror = () => { setTimeout(connectSSE, 3000); };
}

// ── Sorted student IDs ──────────────────────────────────
function getSortedIds() {
  return Array.from(students.values())
    .sort((a, b) => {
      const pA = a.total > 0 ? a.score / a.total : 0;
      const pB = b.total > 0 ? b.score / b.total : 0;
      return pB !== pA ? pB - pA : (b.score || 0) - (a.score || 0);
    })
    .map(s => s.studentId);
}

// ── Flash only on new answer (total changed) ────────────
function flashCard(studentId, prev) {
  const curr = students.get(studentId);
  if (!prev || !curr) return;
  if (curr.total === (prev.total || 0)) return; // no new answer → no flash
  setTimeout(() => {
    const card = document.getElementById('card-' + studentId);
    if (!card) return;
    const wasCorrect = curr.score > (prev.score || 0);
    const cls = wasCorrect ? 'flash-ok' : 'flash-err';
    card.classList.add(cls);
    setTimeout(() => card.classList.remove(cls), 800);
  }, 50);
}

// ── Update individual card DOM elements in-place ────────
// Never recreates the element — only updates text/styles inside it
function updateCardInPlace(studentId, prev) {
  const s = students.get(studentId);
  if (!s) return;
  const card = document.getElementById('card-' + studentId);
  if (!card) { renderAllCards(); return; } // card not rendered yet → full render

  const total = s.total || 0;
  const score = s.score || 0;
  const wrong = total - score;
  const pct = total > 0 ? Math.round(score / total * 100) : 0;
  const col = pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--amber)' : 'var(--red)';
  const barBg = pct >= 70 ? '#059669' : pct >= 40 ? '#d97706' : '#dc2626';
  const isFocused = s.focused !== false;
  const tabSw = s.tabSwitches || 0;
  const awaySec = s.awaySeconds || 0;

  // Decode level from total field: level = floor(total / 1000) + 1
  const level = Math.floor(total / 1000) + 1;
  const levelTotal = total % 1000;
  const displayTotal = levelTotal;
  const displayWrong = displayTotal - score;
  const displayPct = displayTotal > 0 ? Math.round(score / displayTotal * 100) : 0;
  const displayCol = displayPct >= 70 ? 'var(--green)' : displayPct >= 40 ? 'var(--amber)' : 'var(--red)';
  const displayBarBg = displayPct >= 70 ? '#059669' : displayPct >= 40 ? '#d97706' : '#dc2626';

  // Update stats
  const statVals = card.querySelectorAll('.s-stat-val');
  if (statVals[0]) statVals[0].textContent = score;
  if (statVals[1]) statVals[1].textContent = displayWrong;
  if (statVals[2]) statVals[2].textContent = displayTotal;

  // Update percentage
  const pctEl = card.querySelector('.s-card-pct');
  if (pctEl) { pctEl.textContent = displayPct + '%'; pctEl.style.color = displayCol; }

  // Update bar
  const barFill = card.querySelector('.s-bar-fill');
  if (barFill) { barFill.style.width = displayPct + '%'; barFill.style.background = displayBarBg; }

  // Update level badge
  const lvBadge = card.querySelector('.s-card-level');
  if (lvBadge && level >= 1 && level <= 5) lvBadge.textContent = level + '-деңгей';

  // Update focus dot
  const dot = card.querySelector('.s-focus-dot');
  if (dot) { dot.className = 's-focus-dot ' + (isFocused ? 'on' : 'off'); }
  const focusTxt = card.querySelector('.s-focus-text');
  if (focusTxt) { focusTxt.className = 's-focus-text' + (isFocused ? '' : ' away'); focusTxt.textContent = isFocused ? 'Экранда' : 'Сыртта'; }

  // Update tab warning
  const footer = card.querySelector('.s-card-footer');
  if (footer) {
    let warn = footer.querySelector('.tab-warn');
    if (tabSw > 0) {
      if (!warn) { warn = document.createElement('span'); warn.className = 'tab-warn'; footer.appendChild(warn); }
      warn.textContent = `👀 ${tabSw}× · ${awaySec}с`;
    } else {
      if (warn) warn.remove();
    }
  }
}

// ── Full card grid render (only when ranking changes) ───
const AV_COLORS = ['#4338ca','#059669','#d97706','#dc2626','#0891b2','#7c3aed','#ec4899','#f97316'];
function renderAllCards() {
  const arr = Array.from(students.values());
  const sorted = arr.sort((a, b) => {
    const pA = a.total > 0 ? a.score / a.total : 0;
    const pB = b.total > 0 ? b.score / b.total : 0;
    return pB !== pA ? pB - pA : (b.score || 0) - (a.score || 0);
  });
  lastSortedIds = sorted.map(s => s.studentId);
  const medals = ['🥇','🥈','🥉'];

  document.getElementById('cards-grid').innerHTML = sorted.map((s, i) => {
    const total = s.total || 0;
    const score = s.score || 0;

    // Decode level from total: level encoded as (level-1)*1000 + levelTotal
    const level = Math.floor(total / 1000) + 1;
    const levelTotal = total % 1000;
    const wrong = levelTotal - score;
    const pct = levelTotal > 0 ? Math.round(score / levelTotal * 100) : 0;
    const col = pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--amber)' : 'var(--red)';
    const barBg = pct >= 70 ? '#059669' : pct >= 40 ? '#d97706' : '#dc2626';
    const ac = AV_COLORS[i % AV_COLORS.length];
    const isFocused = s.focused !== false;
    const tabSw = s.tabSwitches || 0;
    const awaySec = s.awaySeconds || 0;
    const warn = tabSw > 0 ? `<span class="tab-warn">👀 ${tabSw}× · ${awaySec}с</span>` : '';
    const lvLabel = level >= 1 && level <= 5 ? `<div class="s-card-level">${level}-деңгей</div>` : '';

    return `<div class="s-card" id="card-${s.studentId}" data-rank="${i+1}">
      <div class="s-card-header">
        <span class="s-card-rank">${medals[i] || (i+1)}</span>
        <div class="s-card-av" style="background:${ac}18;color:${ac};border-color:${ac}30">${esc(s.name)[0].toUpperCase()}</div>
        <span class="s-card-name">${esc(s.name)}</span>
        <span class="s-card-pct" style="color:${col}">${pct}%</span>
      </div>
      ${lvLabel}
      <div class="s-card-stats-row">
        <div class="s-stat-box"><div class="s-stat-val g">${score}</div><div class="s-stat-lbl">Дұрыс</div></div>
        <div class="s-stat-box"><div class="s-stat-val r">${wrong}</div><div class="s-stat-lbl">Қате</div></div>
        <div class="s-stat-box"><div class="s-stat-val a">${levelTotal}</div><div class="s-stat-lbl">Барлығы</div></div>
      </div>
      <div class="s-bar"><div class="s-bar-fill" style="width:${pct}%;background:${barBg}"></div></div>
      <div class="s-card-footer">
        <div class="s-focus"><span class="s-focus-dot ${isFocused ? 'on' : 'off'}"></span><span class="s-focus-text${isFocused ? '' : ' away'}">${isFocused ? 'Экранда' : 'Сыртта'}</span></div>
        ${warn}
      </div>
    </div>`;
  }).join('');
}

function updateLiveStats() {
  const arr = Array.from(students.values());
  document.getElementById('live-count').textContent = arr.length;
  const withScore = arr.filter(s => (s.total % 1000) > 0);
  const avg = withScore.length ? Math.round(withScore.reduce((sum, s) => {
    const lt = s.total % 1000;
    return sum + (s.score / lt * 100);
  }, 0) / withScore.length) : 0;
  document.getElementById('avg-pct').textContent = avg;
  const awayArr = arr.filter(s => s.focused === false);
  const pill = document.getElementById('away-pill');
  if (awayArr.length) { pill.style.display = ''; document.getElementById('away-count').textContent = awayArr.length; }
  else pill.style.display = 'none';
}

function updateLobby() {
  const arr = Array.from(students.values());
  document.getElementById('lobby-count').textContent = arr.length;
  const btn = document.getElementById('start-btn');
  btn.disabled = arr.length === 0;
  btn.textContent = arr.length ? `▶ Бастау (${arr.length} оқушы)` : '▶ Бастау (оқушылар күтілуде…)';
  document.getElementById('lobby-list').innerHTML = arr.map(s =>
    `<div class="s-join"><div class="s-join-av" style="background:#4338ca18;color:#4338ca">${esc(s.name)[0].toUpperCase()}</div><div><div class="s-join-name">${esc(s.name)}</div><div class="s-join-sub">✅ Қосылды</div></div></div>`
  ).join('') || '<div class="dots" style="padding:8px 0"><div class="dot"></div><div class="dot"></div><div class="dot"></div><span style="color:var(--muted);font-size:.78rem;margin-left:6px">Күтілуде…</span></div>';
}

// ══════════════════════════════════════════════════════════
//  RESULTS
// ══════════════════════════════════════════════════════════
function showResults() {
  if (quizEnded) return;
  quizEnded = true;
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  if (sseSource) sseSource.close();

  const arr = Array.from(students.values()).sort((a, b) => {
    const ltA = a.total % 1000, ltB = b.total % 1000;
    const pA = ltA > 0 ? a.score / ltA : 0;
    const pB = ltB > 0 ? b.score / ltB : 0;
    return pB - pA;
  });
  const medals = ['🥇','🥈','🥉'];
  document.getElementById('res-sub').textContent = arr.length + ' оқушы';
  document.getElementById('leaderboard').innerHTML = arr.map((s, i) => {
    const lt = s.total % 1000;
    const score = s.score || 0;
    const wrong = lt - score;
    const pct = lt > 0 ? Math.round(score / lt * 100) : 0;
    const col = pct >= 70 ? 'var(--green)' : pct >= 40 ? 'var(--amber)' : 'var(--red)';
    const level = Math.floor((s.total || 0) / 1000) + 1;
    const tabSw = s.tabSwitches || 0, awaySec = s.awaySeconds || 0;
    const warnStr = tabSw > 0 ? `  👀 ${tabSw}× · ${awaySec}с` : '';
    return `<div class="lb-row">
      <div class="lb-rank">${medals[i] || (i+1)}</div>
      <div class="lb-av" style="background:#4338ca18;color:#4338ca">${esc(s.name)[0].toUpperCase()}</div>
      <div class="lb-info"><div class="lb-name">${esc(s.name)}</div><div class="lb-detail">Деңгей ${level} · ✅ ${score}  ❌ ${wrong}  📝 ${lt}  📊 ${pct}%${warnStr}</div></div>
      <div class="lb-pct" style="color:${col}">${pct}%</div>
    </div>`;
  }).join('');
  show('s-results');
  spawnConfetti();
}

function newSession() {
  sessionCode = null; quizEnded = false; lastSortedIds = [];
  students.clear(); selectedLevels.clear();
  document.querySelectorAll('.sec-btn').forEach(b => b.classList.remove('sel'));
  show('s-setup');
}
</script>
</body>
</html>
