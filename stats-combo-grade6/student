const LEVEL_NAMES = { lv1:'1-деңгей', lv2:'2-деңгей', lv3:'3-деңгей', lv4:'4-деңгей', lv5:'5-деңгей' };
const LEVEL_DESCS = { lv1:'Өте оңай', lv2:'Оңай', lv3:'Орташа', lv4:'Қиын', lv5:'Өте қиын' };
const ALL_LEVELS = ['lv1','lv2','lv3','lv4','lv5'];
const PASS_THRESHOLD = 0.7; // 70%
const QUESTIONS_PER_LEVEL = 10;

// ── URL params ───────────────────────────────────────────
const urlParams = new URLSearchParams(location.search);
const urlCode = (urlParams.get('code') || '').toUpperCase();
const lvParam = urlParams.get('lv');

// ── State ────────────────────────────────────────────────
let sessionCode = '';
let studentId = '';
let studentName = '';
let availableLevels = lvParam ? lvParam.split(',').filter(l => ALL_LEVELS.includes(l)) : [...ALL_LEVELS];
let submitInterval = null;
let statusPollInterval = null;
let quizStarted = false;

// Level progress
let levelScores = {}; // { lv1: {correct:X, total:10, passed:true/false}, ... }
let currentLevel = null;
let currentQuestions = [];
let currentQIndex = 0;
let currentCorrect = 0;
let currentWrong = 0;
let selectedOpt = null;
let answered = false;
let quizDone = false;

// Focus tracking
let isFocused = true;
let tabSwitches = 0;
let awaySeconds = 0;
let awayStart = null;

function markAway() {
  if (!isFocused) return;
  isFocused = false; tabSwitches++;
  awayStart = Date.now();
  saveState(); sendScore();
}
function markBack() {
  if (isFocused) return;
  isFocused = true;
  if (awayStart) { awaySeconds += Math.round((Date.now() - awayStart) / 1000); awayStart = null; }
  sendScore();
}
document.addEventListener('visibilitychange', () => { if (document.hidden) markAway(); else markBack(); });
window.addEventListener('blur', markAway);
window.addEventListener('focus', markBack);

// ── localStorage ─────────────────────────────────────────
function saveState() {
  if (!sessionCode) return;
  let ca = awaySeconds;
  if (awayStart) ca += Math.round((Date.now() - awayStart) / 1000);
  try {
    localStorage.setItem(STORAGE_KEY_PREFIX + sessionCode, JSON.stringify({
      studentId, name: studentName, tabSwitches, awaySeconds: ca,
      availableLevels, levelScores, currentLevel,
      currentQIndex, currentCorrect, currentWrong, ts: Date.now()
    }));
  } catch (_) {}
}
function loadState(code) {
  try {
    const raw = localStorage.getItem(STORAGE_KEY_PREFIX + code);
    if (!raw) return null;
    const d = JSON.parse(raw);
    if (Date.now() - d.ts > 3 * 60 * 60 * 1000) { localStorage.removeItem(STORAGE_KEY_PREFIX + code); return null; }
    return d;
  } catch (_) { return null; }
}
function clearState() {
  if (sessionCode) { try { localStorage.removeItem(STORAGE_KEY_PREFIX + sessionCode); } catch (_) {} }
}

// ── Helpers ──────────────────────────────────────────────
function show(id) { document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function spawnConfetti() {
  const w = document.getElementById('confetti'); w.innerHTML = '';
  const cols = ['#4338ca','#2563eb','#d97706','#059669','#dc2626'];
  for (let i = 0; i < 60; i++) { const e = document.createElement('div'); e.className = 'cfp'; const s = 5 + Math.random() * 9; e.style.cssText = `left:${Math.random()*100}vw;width:${s}px;height:${s}px;background:${cols[~~(Math.random()*cols.length)]};border-radius:${Math.random()>.5?'50%':'2px'};animation-duration:${2+Math.random()*3}s;animation-delay:${Math.random()*1.4}s`; w.appendChild(e); }
  setTimeout(() => w.innerHTML = '', 6000);
}

if (urlCode) { document.getElementById('scode').value = urlCode; document.getElementById('code-wrap').style.display = 'none'; }

// ── Reconnect on load ────────────────────────────────────
(async function tryReconnect() {
  if (!urlCode) return;
  const saved = loadState(urlCode);
  if (!saved) return;
  try {
    const res = await fetch(`${BACKEND}/status?code=${urlCode}`);
    const data = await res.json();
    if (data.status === 'not_found' || data.status === 'ended') { clearState(); return; }
    sessionCode = urlCode;
    studentId = saved.studentId;
    studentName = saved.name;
    tabSwitches = saved.tabSwitches || 0;
    awaySeconds = saved.awaySeconds || 0;
    if (saved.availableLevels?.length) availableLevels = saved.availableLevels;
    if (saved.levelScores) levelScores = saved.levelScores;
    if (saved.currentLevel) currentLevel = saved.currentLevel;
    currentQIndex = saved.currentQIndex || 0;
    currentCorrect = saved.currentCorrect || 0;
    currentWrong = saved.currentWrong || 0;
    if (data.status === 'active') startQuiz();
    else if (data.status === 'waiting') showWait();
  } catch (_) {}
})();

// ════ JOIN ════
async function joinQuiz() {
  const name = document.getElementById('sname').value.trim();
  const code = (urlCode || document.getElementById('scode').value.trim()).toUpperCase();
  const errEl = document.getElementById('join-err');
  if (!name) { errEl.textContent = 'Атыңызды жазыңыз'; errEl.classList.add('on'); return; }
  if (code.length < 4) { errEl.textContent = 'Бөлме кодын енгізіңіз'; errEl.classList.add('on'); return; }
  errEl.classList.remove('on');
  const btn = document.getElementById('join-btn');
  btn.disabled = true; btn.textContent = '⏳ Қосылуда...';
  sessionCode = code; studentName = name;
  studentId = 'stu_' + Math.random().toString(36).substr(2, 9);
  try {
    const res = await fetch(`${BACKEND}/status?code=${code}`);
    const data = await res.json();
    if (data.status === 'not_found') { errEl.textContent = 'Бөлме табылмады.'; errEl.classList.add('on'); btn.disabled = false; btn.textContent = '🚀 Кіру'; return; }
    if (data.status === 'ended') { errEl.textContent = 'Бұл сабақ аяқталған.'; errEl.classList.add('on'); btn.disabled = false; btn.textContent = '🚀 Кіру'; return; }
    levelScores = {};
    await sendScore();
    saveState();
    btn.disabled = false; btn.textContent = '🚀 Кіру';
    if (data.status === 'active') startQuiz(); else showWait();
  } catch (e) {
    errEl.textContent = 'Серверге қосылу мүмкін болмады.';
    errEl.classList.add('on'); btn.disabled = false; btn.textContent = '🚀 Кіру';
  }
}
document.addEventListener('keydown', e => { if (document.getElementById('s-join').classList.contains('active') && e.key === 'Enter') joinQuiz(); });

// ════ WAIT ════
function showWait() {
  document.getElementById('wait-name').textContent = studentName;
  show('s-wait');
  if (statusPollInterval) clearInterval(statusPollInterval);
  statusPollInterval = setInterval(pollStatus, 2000);
}
async function pollStatus() {
  try {
    const res = await fetch(`${BACKEND}/status?code=${sessionCode}`);
    const data = await res.json();
    if (data.status === 'active') { clearInterval(statusPollInterval); statusPollInterval = null; startQuiz(); }
    else if (data.status === 'ended' || data.status === 'not_found') { clearInterval(statusPollInterval); statusPollInterval = null; showFinalResults(); }
  } catch (_) {}
}

// ════ START QUIZ ════
function startQuiz() {
  if (quizStarted) return;
  quizStarted = true;
  sendScore();
  if (submitInterval) clearInterval(submitInterval);
  submitInterval = setInterval(sendScore, 5000);
  showLevelSelect();
}

// ════ LEVEL SELECT ════
function showLevelSelect() {
  renderLevelGrid();
  show('s-levels');
}

function renderLevelGrid() {
  const grid = document.getElementById('lv-grid');
  grid.innerHTML = availableLevels.map(lv => {
    const sc = levelScores[lv];
    let badge = '', locked = false;
    if (sc) {
      const pct = Math.round(sc.correct / QUESTIONS_PER_LEVEL * 100);
      if (sc.passed) badge = `<span class="lv-badge badge-pass">✓ Өтті ${pct}%</span>`;
      else badge = `<span class="lv-badge badge-fail">✗ Қайта ${pct}%</span>`;
    } else {
      badge = `<span class="lv-badge badge-new">Жаңа</span>`;
    }
    const colors = { lv1:'#059669', lv2:'#0891b2', lv3:'#d97706', lv4:'#dc2626', lv5:'#7c3aed' };
    const emojis = { lv1:'⭐', lv2:'⭐⭐', lv3:'⭐⭐⭐', lv4:'⭐⭐⭐⭐', lv5:'⭐⭐⭐⭐⭐' };
    const num = lv.replace('lv', '');
    const col = colors[lv];
    return `<button class="lv-btn${locked?' locked':''}" onclick="${locked?'':` selectLevel('${lv}')`}">
      <div class="lv-num" style="background:${col}18;color:${col}">${emojis[lv]}</div>
      <div class="lv-info">
        <div class="lv-name">${LEVEL_NAMES[lv]}</div>
        <div class="lv-desc">${LEVEL_DESCS[lv]} · 10 сұрақ</div>
      </div>
      ${badge}
    </button>`;
  }).join('');
}

function selectLevel(lv) {
  currentLevel = lv;
  currentQIndex = 0; currentCorrect = 0; currentWrong = 0;
  selectedOpt = null; answered = false;
  // Shuffle and take all 10 questions (full bank is already 10)
  currentQuestions = [...QUESTION_BANK[lv]].sort(() => Math.random() - 0.5);
  updateQuizStats();
  loadQuestion();
  show('s-quiz');
}

// ════ QUIZ ════
function loadQuestion() {
  const q = currentQuestions[currentQIndex];
  const labels = ['A', 'B', 'C', 'D'];
  selectedOpt = null; answered = false;
  document.getElementById('q-num-badge').textContent = `${currentQIndex + 1}/${QUESTIONS_PER_LEVEL}`;
  document.getElementById('q-level-badge').textContent = LEVEL_NAMES[currentLevel];
  document.getElementById('progress-fill').style.width = (currentQIndex / QUESTIONS_PER_LEVEL * 100) + '%';
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('opts').innerHTML = q.opts.map((o, i) => `
    <div class="opt" data-idx="${i}" onclick="selectOpt(${i})">
      <span class="opt-label">${labels[i]}</span>
      <span class="opt-text">${o}</span>
    </div>`).join('');
  document.getElementById('feedback').classList.add('hidden');
  document.getElementById('check-btn').disabled = true;
  document.getElementById('check-btn').classList.remove('hidden');
  document.getElementById('next-btn').classList.add('hidden');
}

function selectOpt(idx) {
  if (answered) return;
  document.querySelectorAll('.opt').forEach(o => o.classList.remove('selected'));
  document.querySelectorAll('.opt')[idx].classList.add('selected');
  selectedOpt = idx;
  document.getElementById('check-btn').disabled = false;
}

function checkAnswer() {
  if (selectedOpt === null || answered) return;
  answered = true;
  const q = currentQuestions[currentQIndex];
  const labels = ['A', 'B', 'C', 'D'];
  const correctIdx = labels.indexOf(q.ans);
  const isCorrect = selectedOpt === correctIdx;
  const opts = document.querySelectorAll('.opt');
  opts.forEach(o => o.style.pointerEvents = 'none');
  opts[correctIdx].classList.add('correct');
  if (!isCorrect) opts[selectedOpt].classList.add('wrong');
  if (isCorrect) currentCorrect++; else currentWrong++;
  const fb = document.getElementById('feedback');
  fb.classList.remove('hidden', 'correct', 'wrong');
  fb.classList.add(isCorrect ? 'correct' : 'wrong');
  fb.textContent = isCorrect ? '✓ Дұрыс!' : `✗ Қате! Дұрыс жауап: ${q.opts[correctIdx]}`;
  updateQuizStats();
  saveState();
  sendScore();
  document.getElementById('check-btn').classList.add('hidden');
  document.getElementById('next-btn').classList.remove('hidden');
}

function nextQuestion() {
  currentQIndex++;
  if (currentQIndex >= QUESTIONS_PER_LEVEL) {
    finishLevel();
  } else {
    loadQuestion();
  }
}

function updateQuizStats() {
  const done = currentCorrect + currentWrong;
  const pct = done > 0 ? Math.round(currentCorrect / done * 100) : 0;
  document.getElementById('st-qnum').textContent = `${currentQIndex + 1}/${QUESTIONS_PER_LEVEL}`;
  document.getElementById('st-correct').textContent = currentCorrect;
  document.getElementById('st-wrong').textContent = currentWrong;
  document.getElementById('st-pct').textContent = pct + '%';
}

function finishLevel() {
  const passed = currentCorrect / QUESTIONS_PER_LEVEL >= PASS_THRESHOLD;
  levelScores[currentLevel] = { correct: currentCorrect, total: QUESTIONS_PER_LEVEL, passed };
  const pct = Math.round(currentCorrect / QUESTIONS_PER_LEVEL * 100);
  document.getElementById('lv-res-emoji').textContent = passed ? '🎉' : pct >= 40 ? '👍' : '💪';
  document.getElementById('lv-res-title').textContent = passed ? `${LEVEL_NAMES[currentLevel]} — Өтті!` : `${LEVEL_NAMES[currentLevel]} — Қайталап көріңіз`;
  document.getElementById('lv-res-sub').textContent = LEVEL_DESCS[currentLevel];
  document.getElementById('lv-res-correct').textContent = currentCorrect;
  document.getElementById('lv-res-wrong').textContent = QUESTIONS_PER_LEVEL - currentCorrect;
  document.getElementById('lv-res-pct').textContent = pct + '%';
  if (passed) spawnConfetti();
  const actions = document.getElementById('lv-res-actions');
  const allPassed = availableLevels.every(lv => levelScores[lv]?.passed);
  actions.innerHTML = '';
  if (allPassed) {
    actions.innerHTML = '<button class="btn btn-primary btn-block" onclick="showFinalResults()">🏆 Нәтижелерді көру</button>';
  } else {
    if (!passed) {
      actions.innerHTML += `<button class="btn btn-primary btn-block" onclick="selectLevel('${currentLevel}')">🔄 Қайталау</button>`;
    }
    actions.innerHTML += '<button class="btn btn-ghost btn-block" onclick="showLevelSelect()">📚 Деңгей таңдау</button>';
  }
  sendScore();
  saveState();
  show('s-lv-result');
}

// ════ SEND SCORE ════
// Encodes current level into `total` field: total = (levelIndex)*1000 + questionsAnswered
async function sendScore(finished) {
  if (!sessionCode || !studentName) return;
  let ca = awaySeconds;
  if (awayStart) ca += Math.round((Date.now() - awayStart) / 1000);
  const levelIdx = currentLevel ? ALL_LEVELS.indexOf(currentLevel) : 0;
  const levelTotal = currentCorrect + currentWrong;
  const encodedTotal = levelIdx * 1000 + levelTotal;
  try {
    const res = await fetch(`${BACKEND}/submit`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        code: sessionCode, studentId, name: studentName,
        score: currentCorrect,
        total: encodedTotal,
        finished: finished === true,
        focused: isFocused, tabSwitches, awaySeconds: ca
      })
    });
    const data = await res.json();
    if (data.status === 'ended' || data.status === 'not_found') showFinalResults();
  } catch (_) {}
}

// ════ FINAL RESULTS ════
function showFinalResults() {
  if (quizDone) return;
  quizDone = true;
  if (submitInterval) { clearInterval(submitInterval); submitInterval = null; }
  if (statusPollInterval) { clearInterval(statusPollInterval); statusPollInterval = null; }
  const totalCorrect = Object.values(levelScores).reduce((s, v) => s + v.correct, 0);
  const totalQ = Object.values(levelScores).reduce((s, v) => s + v.total, 0);
  const pct = totalQ > 0 ? Math.round(totalCorrect / totalQ * 100) : 0;
  document.getElementById('res-correct').textContent = totalCorrect;
  document.getElementById('res-wrong').textContent = totalQ - totalCorrect;
  document.getElementById('res-pct').textContent = pct + '%';
  document.getElementById('res-emoji').textContent = pct >= 70 ? '🎉' : pct >= 40 ? '👍' : '💪';
  show('s-results');
  if (pct >= 70) spawnConfetti();
  clearState();
}
</script>
